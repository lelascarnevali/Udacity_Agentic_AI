{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File (Integrated Terminal)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/.venv/bin/python",
      "pythonArgs": [
        "-Xfrozen_modules=off"
      ],
      "env": {
        "PYDEVD_USE_SYS_MONITORING": "0"
      },
      "purpose": [
        "debug-in-terminal"
      ]
    }
  ]
}
